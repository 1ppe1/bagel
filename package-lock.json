{
  "name": "docsync",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "docsync",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "bin": {
        "docsync": "packages/cli/bin/docsync.mjs"
      },
      "devDependencies": {
        "typescript": "^6.0.3"
      }
    },
    "apps/api": {
      "name": "@docsync/api",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@docsync/web",
      "version": "0.1.0"
    },
    "node_modules/@docsync/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@docsync/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@docsync/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@docsync/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/typescript": {
      "version": "6.0.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-6.0.3.tgz",
      "integrity": "sha512-y2TvuxSZPDyQakkFRPZHKFm+KKVqIisdg9/CZwm9ftvKXLP8NRWj38/ODjNbr43SsoXqNuAisEf1GdCxqWcdBw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/cli": {
      "name": "@docsync/cli",
      "version": "0.1.0",
      "bin": {
        "docsync": "bin/docsync.mjs"
      }
    },
    "packages/core": {
      "name": "@docsync/core",
      "version": "0.1.0"
    }
  }
}
